# Spotify Developer Credentials
# Obtain these by creating an app on https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Spotify OAuth Redirect URI (Must match the setting in your Spotify App dashboard)
SPOTIFY_REDIRECT_URI=http://localhost:8080

# Custom Playlists (Optional - Replace with your own Spotify playlist URIs or IDs)
# Format: spotify:playlist:PLAYLIST_ID or just PLAYLIST_ID
# Calm Mode (< 80 KPM) - e.g. Lofi Beats
SPOTIFY_PLAYLIST_CALM=spotify:playlist:37i9dQZF1DWWQRwui0ExPn
# Flow State (80 - 180 KPM) - e.g. Chill Lofi Study Beats
SPOTIFY_PLAYLIST_FLOW=spotify:playlist:37i9dQZF1DX8Uebhpia6b0
# Sprint Mode (> 180 KPM) - e.g. Synthwave / Retrowave
SPOTIFY_PLAYLIST_SPRINT=spotify:playlist:37i9dQZF1DX8T6tZ55487w

# Thresholds and Intervals (Optional)
KPM_CALM_LIMIT=80
KPM_FLOW_LIMIT=180
DEBOUNCE_SECONDS=15.0
